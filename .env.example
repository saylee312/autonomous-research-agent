# ============================================================================
# Environment Configuration for Autonomous Research Agent
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# LLM Configuration
# ============================================================================
# Groq API key for GPT models
GROQ_API_KEY=your_groq_api_key_here

# Model to use for research synthesis
MODEL_NAME=gpt-4-turbo
# Alternative: gpt-4, gpt-3.5-turbo

# ============================================================================
# Search APIs
# ============================================================================
# Tavily API key for advanced web search
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================================
# Database Configuration
# ============================================================================
# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017
# For Docker: mongodb://mongo:27017

# Database name
MONGO_DB_NAME=research_agent

# ============================================================================
# Vector Database (Chroma)
# ============================================================================
# Chroma server host (for local: localhost or 127.0.0.1)
CHROMA_HOST=localhost
# For Docker: use service name 'chroma'

# Chroma server port
CHROMA_PORT=8000

# ============================================================================
# Application Configuration
# ============================================================================
# Debug mode (true/false)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# API Configuration
# ============================================================================
# Maximum number of retries for external API calls
MAX_RETRIES=3

# Request timeout in seconds
REQUEST_TIMEOUT=30
